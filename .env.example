SERVER_NAME=app-prod-1
SERVER_LOCATION=fra1
TELEGRAM_BOT_TOKEN=123456789:telegram-bot-token
TELEGRAM_CHAT_ID=-1001234567890
NGINX_ACCESS_LOG_PATH=/host/var/log/nginx/access.log
STATE_DIR=./state
TIMEZONE=UTC
PROCESS_ALERT_POLICY=risk-based
HOST_PROC_PATH=/host/proc
LISTEN_ADDRESS=:8081
HEALTH_PATH=/healthz
CPU_THRESHOLD=90
RAM_THRESHOLD=90
RESOURCE_BREACH_SECONDS=10
NEW_IP_NOTIFY_ENABLED=true
REQUEST_BURST_THRESHOLD=100
REQUEST_BURST_WINDOW_SECONDS=10
ALERT_COOLDOWN_SECONDS=300
PROCESS_SCAN_INTERVAL_SECONDS=5
REQUEST_POLL_INTERVAL_SECONDS=1
RESOURCE_POLL_INTERVAL_SECONDS=2
LOG_LEVEL=INFO
